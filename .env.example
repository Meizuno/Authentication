PORT=8080
# In production use sslmode=require (or verify-full) so the DB connection is
# encrypted; sslmode=disable is for local dev only.
DATABASE_URL=postgres://user:password@localhost:5432/authentication?sslmode=disable

# Gin mode: release (default) or debug. Leave unset for release in production.
GIN_MODE=release

# Structured-log level: debug | info | warn | error (default info).
LOG_LEVEL=info
JWT_SECRET=change-me-to-a-random-secret

# Access-token signing algorithm: HS256 (default, symmetric shared secret) |
# EdDSA (Ed25519, recommended) | RS256. Flip to an asymmetric alg only after
# consumers can verify via JWKS — see ROLLOUT.md.
JWT_SIGNING_ALG=HS256
# Private key (PEM) for asymmetric signing, inline or via a file path. Required
# when JWT_SIGNING_ALG is EdDSA or RS256. The public half is published at
# /.well-known/jwks.json.
JWT_PRIVATE_KEY=
JWT_PRIVATE_KEY_FILE=
# Issuer and audience stamped into and validated on access tokens. Audience may
# be comma-separated. Leave empty to omit iss/aud (legacy behavior).
JWT_ISSUER=
JWT_AUDIENCE=
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Comma-separated list of allowed emails. Leave empty to allow all.
ALLOWED_EMAILS=

# Comma-separated allowlist of exact post-login redirect targets. A redirect_url
# that is not an exact match is rejected (closes the open-redirect). Leave empty
# to disable redirecting (tokens are then delivered via cookies + JSON only).
ALLOWED_REDIRECT_URLS=

# Cookie security. Keep COOKIE_SECURE=true in production (HTTPS); set false only
# for non-HTTPS local dev. COOKIE_DOMAIN scopes auth cookies (empty = host-only).
COOKIE_SECURE=true
COOKIE_DOMAIN=

# Per-client rate limiting on /google, /google/callback, /refresh. Token bucket:
# RATE_LIMIT_RPS sustained requests/sec, RATE_LIMIT_BURST the bucket size.
# In-memory, per instance (fine for a single replica).
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
