PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/authentication?sslmode=disable
JWT_SECRET=change-me-to-a-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Comma-separated list of allowed emails. Leave empty to allow all.
ALLOWED_EMAILS=

# Comma-separated allowlist of exact post-login redirect targets. A redirect_url
# that is not an exact match is rejected (closes the open-redirect). Leave empty
# to disable redirecting (tokens are then delivered via cookies + JSON only).
ALLOWED_REDIRECT_URLS=

# Cookie security. Keep COOKIE_SECURE=true in production (HTTPS); set false only
# for non-HTTPS local dev. COOKIE_DOMAIN scopes auth cookies (empty = host-only).
COOKIE_SECURE=true
COOKIE_DOMAIN=
